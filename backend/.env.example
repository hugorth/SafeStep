# SafeStep Backend Environment Variables
# Copy this file to .env and update with your values

# ==================== SERVER CONFIGURATION ====================
PORT=3001
NODE_ENV=development

# ==================== DATABASE ====================
# Option 1: Local MongoDB (Development)
MONGODB_URI=mongodb://localhost:27017/safestep

# Option 2: MongoDB Atlas (Production - décommentez et configurez)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/safestep?retryWrites=true&w=majority

# ==================== JWT SECURITY ====================
# IMPORTANT: Change these in production! Use long random strings
JWT_SECRET=safestep-ultra-secure-secret-key-change-in-production-2024-$(openssl rand -hex 32)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ==================== PASSWORD SECURITY ====================
BCRYPT_ROUNDS=12

# ==================== RATE LIMITING ====================
# Window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ==================== CORS ====================
# In production, specify your frontend URL
CORS_ORIGIN=*

# ==================== SESSION & COOKIES ====================
SESSION_SECRET=safestep-session-secret-change-in-production-$(openssl rand -hex 32)
COOKIE_MAX_AGE=604800000

# ==================== EMAIL CONFIGURATION (Optional) ====================
# For password reset emails - configure if needed
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=SafeStep <noreply@safestep.com>

# ==================== ADMIN ACCOUNT ====================
# Default admin account created on first startup
ADMIN_EMAIL=admin@safestep.com
ADMIN_PASSWORD=Admin123!SecurePassword
ADMIN_NAME=Administrator

# ==================== WEBSOCKET ====================
WS_HEARTBEAT_INTERVAL=30000
WS_MESSAGE_RATE_LIMIT=100

# ==================== DATA SIMULATION ====================
SIMULATION_ENABLED=true
SIMULATION_INTERVAL=2000

# ==================== LOGGING ====================
LOG_LEVEL=info
LOG_FILE=./logs/safestep.log

# ==================== PRODUCTION CHECKLIST ====================
# Before deploying to production:
# [ ] Change JWT_SECRET to a strong random value
# [ ] Change SESSION_SECRET to a strong random value
# [ ] Change ADMIN_PASSWORD to a strong password
# [ ] Update MONGODB_URI to your production database
# [ ] Set CORS_ORIGIN to your frontend URL
# [ ] Set NODE_ENV=production
# [ ] Configure email settings
# [ ] Enable HTTPS
# [ ] Configure monitoring/logging
