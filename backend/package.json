{
  "name": "safestep-backend",
  "version": "1.0.0",
  "description": "Backend simulateur pour SafeStep - Chaussures connectées avec ESP32",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node -e \"require('dotenv').config(); require('./config/database')().then(() => require('./utils/initUsers').initializeDefaultUsers()).then(() => process.exit(0))\""
  },
  "keywords": [
    "safestep",
    "esp32",
    "smart-shoes",
    "iot",
    "health-monitoring"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.3",
    "dotenv": "^16.3.1",
    "validator": "^13.11.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
